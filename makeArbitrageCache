#!/bin/zsh

#
# Create a list of items that are known (recently seen) to have
# arbitrage opportunities. When accessing the auction house this
# list can be scanned to see what arbitrages are available at
# that moment.
#

LATEST=~/dev/wow/generated/arbitrageLatest.log

echo "local ItemIDs = {"
# Collect item arbitrages of the most recent scan
cat ${LATEST} | sort | uniq -c | sort -nr | sed "s/^.*    /    /1" | sort -un
echo "}"
echo
echo "ArbitrageCache = {"
echo "    ItemIDs = ItemIDs,"
echo "}"
